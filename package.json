{
  "name": "thecrux",
  "version": "0.1.0",
  "description": "A self-hosted code hosting solution — like GitHub, built incrementally.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "crux": "node --import tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "rm -rf .testdata && CRUX_DATA_DIR=.testdata CRUX_SECRET=test-secret node --import tsx --test --test-concurrency=1 tests/*.test.ts"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "sanitize-html": "^2.17.5",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/ssh2": "^1.15.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
