<%- include("partials/header", {
  title: "the crux is in the code",
  crumb: "~",
  description: "thecrux is a keyboard-first, self-hosted git server — private by default, push over Smart-HTTP with revocable tokens, issues and pull requests included. Your code never leaves your server. The crux is in the code.",
}) %>

<section class="hero">
  <p class="hero-eyebrow">// self-hosted, private git — on your own server</p>

  <h1 class="hero-wordmark"><%= appName %><span class="brand-caret">❯</span></h1>

  <p class="hero-tagline">The crux is in the&nbsp;<span class="hero-code">code</span>.</p>

  <p class="hero-sub">
    A keyboard-first, self-hosted home for your code — <strong>private by
    default</strong>, push over Smart-HTTP, issues and pull requests included.
    No telemetry, no sprawl. Your code never leaves your&nbsp;server.
  </p>

  <div class="hero-cta">
    <% if (locals.canRegister) { %>
      <a class="kbtn primary" href="/register">
        <span class="kbtn-key">n</span> create account
      </a>
      <a class="kbtn" href="/login">sign in</a>
    <% } else { %>
      <a class="kbtn primary" href="/login">sign in</a>
    <% } %>
    <a class="hero-link" href="#how">
      see how it works <span class="hero-link-go">↓</span>
    </a>
  </div>
</section>

<section class="termcard" id="how" aria-hidden="true">
  <div class="termcard-bar">
    <span class="termdot"></span><span class="termdot"></span><span class="termdot"></span>
    <span class="termcard-title">~/projects/atlas — git push</span>
  </div>
  <pre class="termcard-body"><span class="t-prompt">crux<span class="brand-caret">❯</span></span> <span class="t-cmd">git push origin main</span>
<span class="t-dim">Enumerating objects: 14, done.</span>
<span class="t-dim">Writing objects: 100% (8/8), 1.21 KiB | 1.21 MiB/s, done.</span>
<span class="t-ok">remote:</span> resolved <span class="t-accent">3 commits</span> · opened pull request <span class="t-accent">#42</span>
<span class="t-ok">remote:</span> review at <span class="t-link">/atlas/pull/42</span>
<span class="t-prompt">crux<span class="brand-caret">❯</span></span> <span class="t-cmd">crux diff --crux</span>

  <span class="t-file">src/auth/session.ts</span>
<span class="t-add">+  const token = randomBytes(32).toString("base64url");</span>
<span class="t-crux">+  setCookie(res, token, { httpOnly: true, sameSite: "lax" }); <span class="t-tag">← the crux</span></span>
<span class="t-dim"> </span> return token;
<span class="t-caret">▋</span></pre>
</section>

<div class="clone-pitch">
  <span class="clone-pitch-label">push from anywhere with plain git —</span>
  <div class="copy-row" data-copy="<%= cloneUrl %>">
    <code class="copy-text">git clone <%= cloneUrl %></code>
    <button class="copy-btn" type="button" title="Copy">copy</button>
  </div>
</div>

<section class="feats">
  <a class="feat" href="/register">
    <span class="feat-glyph">⚿</span>
    <span class="feat-h">Private by default</span>
    <span class="feat-p">New repos are private — browsing and cloning are gated to the people you choose. Flip to public when you want.</span>
  </a>
  <a class="feat" href="/register">
    <span class="feat-glyph">❖</span>
    <span class="feat-h">Your server, your rules</span>
    <span class="feat-p">An admin who controls the instance: open, invite-only or closed registration, and per-repo collaborators.</span>
  </a>
  <a class="feat" href="/register">
    <span class="feat-glyph">◈</span>
    <span class="feat-h">Token-based access</span>
    <span class="feat-p">Clone and push with revocable, per-device access tokens — your password never lands in <code>git</code>'s config.</span>
  </a>
  <a class="feat" href="/register">
    <span class="feat-glyph">⇅</span>
    <span class="feat-h">Smart-HTTP git</span>
    <span class="feat-p">Clone, fetch and push over plain HTTP. No daemons, no special client — just <code>git</code>.</span>
  </a>
  <a class="feat" href="/register">
    <span class="feat-glyph">◇</span>
    <span class="feat-h">Issues &amp; pull requests</span>
    <span class="feat-p">Real diffs, labels and assignees. Review where the work is — keyboard-first, with a <kbd>⌘K</kbd> palette.</span>
  </a>
  <a class="feat" href="/register">
    <span class="feat-glyph">⬡</span>
    <span class="feat-h">Self-hosted &amp; private</span>
    <span class="feat-p">A single Node app + Docker, behind your own TLS. No telemetry; your code never leaves your box.</span>
  </a>
</section>

<section class="endcta">
  <p class="endcta-line"><span class="t-prompt">crux<span class="brand-caret">❯</span></span> <span class="t-cmd">start</span></p>
  <h2 class="endcta-h">Get to the crux of your code.</h2>
  <div class="hero-cta">
    <% if (locals.canRegister) { %>
      <a class="kbtn primary" href="/register"><span class="kbtn-key">n</span> create account</a>
      <a class="kbtn" href="/login">sign in</a>
    <% } else { %>
      <a class="kbtn primary" href="/login">sign in</a>
    <% } %>
  </div>
</section>

<%- include("partials/footer") %>
