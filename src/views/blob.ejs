<%- include("partials/header", { title: subpath, crumb: "~/repos/" + repo.name + "/" + subpath }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">cat <%= subpath %></span>
</section>

<%- include("partials/crumbs") %>

<div class="card blobview">
  <div class="blob-meta">
    <span class="blob-stat"><%= humanSize(blob.size) %></span>
    <% if (!blob.isBinary && !blob.tooLarge) { %>
      <span class="blob-stat"><%= lineCount %> <%= lineCount === 1 ? "line" : "lines" %></span>
    <% } %>
    <% if (language) { %><span class="blob-lang"><%= language %></span><% } %>
    <% if (blob.isBinary) { %><span class="blob-stat blob-binary">binary</span><% } %>
    <% if (markdownHtml) { %>
      <div class="blob-toggle" role="group">
        <button class="blob-tab is-active" type="button" data-blob-view="rendered">rendered</button>
        <button class="blob-tab" type="button" data-blob-view="source">source</button>
      </div>
    <% } %>
    <a class="blob-raw" href="<%= rawUrl %>">raw</a>
  </div>

  <% if (blob.text !== null) { %>
    <% if (markdownHtml) { %>
      <div class="md-body" id="blob-rendered"><%- markdownHtml %></div>
    <% } %>
    <div class="codeview<%= markdownHtml ? ' is-hidden' : '' %>" id="blob-source">
      <pre class="gutter"><% for (var i = 1; i <= lineCount; i++) { %><span class="lineno"><%= i %></span><% } %></pre>
      <pre class="codecol"><code class="hljs"><%- highlightedHtml %></code></pre>
    </div>
  <% } else { %>
    <div class="blob-notshown">
      <% if (blob.isBinary) { %>
        <p>Binary file — not shown.</p>
      <% } else { %>
        <p>File is too large to display inline (<%= humanSize(blob.size) %>).</p>
      <% } %>
      <a class="kbtn" href="<%= rawUrl %>">view raw</a>
    </div>
  <% } %>
</div>

<%- include("partials/footer") %>
