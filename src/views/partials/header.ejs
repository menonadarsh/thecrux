<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <%
    var pageTitle = typeof title !== "undefined" ? title + " · " + appName : appName;
    var metaDesc = typeof description !== "undefined"
      ? description
      : "Self-hosted, keyboard-first git hosting. Push over Smart-HTTP, browse trees, review pull requests. The crux is in the code.";
  %>
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= metaDesc %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="<%= appName %>" />
  <meta property="og:title" content="<%= pageTitle %>" />
  <meta property="og:description" content="<%= metaDesc %>" />
  <% if (locals.canonicalUrl) { %><meta property="og:url" content="<%= canonicalUrl %>" /><% } %>
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<%= pageTitle %>" />
  <meta name="twitter:description" content="<%= metaDesc %>" />
  <link rel="stylesheet" href="/style.css" />
  <script>
    // Apply theme before first paint to avoid a flash.
    (function () {
      try {
        var saved = localStorage.getItem("crux-theme");
        var theme = saved || (matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
        document.documentElement.setAttribute("data-theme", theme);
      } catch (e) {
        document.documentElement.setAttribute("data-theme", "dark");
      }
    })();
  </script>
</head>
<body>
  <div class="shell">
    <header class="masthead">
      <a class="brand" href="/" aria-label="Home">
        <span class="brand-prompt">crux</span><span class="brand-caret">❯</span>
        <span class="brand-path"><%= typeof crumb !== "undefined" ? crumb : "~" %></span>
      </a>
      <div class="masthead-tools">
        <button class="kbtn" type="button" data-action="palette" title="Command palette (⌘K)">
          <span class="kbtn-key">⌘K</span> search
        </button>
        <button class="kbtn icon" type="button" data-action="theme" title="Toggle theme (t)" aria-label="Toggle theme">
          <span class="theme-icon theme-icon-dark">◑</span>
          <span class="theme-icon theme-icon-light">◐</span>
        </button>
        <% if (locals.currentUser) { %>
          <div class="usermenu" data-usermenu>
            <button class="kbtn" type="button" data-usermenu-toggle>
              <span class="user-glyph">●</span> <%= currentUser.username %>
              <% if (currentUser.admin) { %><span class="kbtn-key">admin</span><% } %>
            </button>
            <div class="usermenu-pop" data-usermenu-pop hidden>
              <span class="usermenu-name"><%= currentUser.displayName %></span>
              <a class="usermenu-item" href="/<%= currentUser.username %>">your repositories</a>
              <a class="usermenu-item" href="/orgs/new">new organization</a>
              <a class="usermenu-item" href="/settings">settings</a>
              <% if (currentUser.admin) { %>
                <a class="usermenu-item" href="/admin">admin panel</a>
              <% } %>
              <form method="post" action="/logout">
                <button class="usermenu-item" type="submit">sign out</button>
              </form>
            </div>
          </div>
        <% } else { %>
          <a class="kbtn" href="/login">sign in</a>
          <% if (locals.canRegister) { %>
            <a class="kbtn primary" href="/register">create account</a>
          <% } %>
        <% } %>
      </div>
    </header>
    <main class="content">
