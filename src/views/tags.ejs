<%- include("partials/header", { title: "tags · " + repo.name, crumb: "~/repos/" + repo.name + "/tags" }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">git tag</span>
  <span class="termline-meta"><%= tags.length %> <%= tags.length === 1 ? "tag" : "tags" %></span>
</section>

<%- include("partials/repobar") %>

<% if (tags.length === 0) { %>
  <div class="blank"><p class="muted">No tags yet.</p></div>
<% } else { %>
  <ul class="reflist" role="list">
    <% tags.forEach(function (t) { %>
      <li class="refrow" data-nav-item data-name="<%= t.name.toLowerCase() %>">
        <span class="refrow-glyph">⌑</span>
        <a class="refrow-name" href="/<%= encodeURIComponent(repo.name) %>/tree/<%= encodeURIComponent(t.name) %>"><%= t.name %></a>
        <% if (t.annotated) { %><span class="tag">annotated</span><% } %>
        <span class="refrow-sub"><%= t.subject %></span>
        <span class="refrow-meta">
          <a class="refrow-hash" href="/<%= encodeURIComponent(repo.name) %>/commit/<%= t.shortHash %>"><%= t.shortHash %></a>
          <% if (t.date) { %><span class="muted"><%= relativeTime(t.date) %></span><% } %>
        </span>
      </li>
    <% }); %>
  </ul>
<% } %>

<%- include("partials/footer") %>
