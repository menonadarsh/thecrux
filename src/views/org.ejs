<%- include("partials/header", { title: org.name, crumb: "~/" + org.name }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">ls ~<%= org.name %></span>
  <span class="termline-meta"><%= repos.length %> <%= repos.length === 1 ? "repository" : "repositories" %></span>
</section>

<div class="page-head">
  <h1 class="user-name"><span class="user-glyph">▣</span> <%= org.displayName %> <span class="tag tag-branch">org</span></h1>
  <p class="muted">@<%= org.name %></p>
</div>

<div class="toolbar">
  <div class="org-members">
    <% members.forEach(function (m) { %>
      <a class="org-member" href="/<%= m.username %>" title="<%= m.role %>">
        <span class="user-glyph">●</span> @<%= m.username %><% if (m.role === "owner") { %><span class="tag tag-admin">owner</span><% } %>
      </a>
    <% }); %>
  </div>
  <span class="toolbar-spacer"></span>
  <% if (isMember) { %><a class="kbtn primary" href="/new">new repository</a><% } %>
  <% if (isOrgOwner) { %><a class="kbtn" href="/orgs/<%= org.name %>/settings">settings</a><% } %>
</div>

<% if (repos.length === 0) { %>
  <div class="blank"><p class="muted">No repositories under @<%= org.name %> yet.</p></div>
<% } else { %>
  <ul class="repos" role="list">
    <% repos.forEach(function (repo) { %>
      <li class="repo" data-nav-item data-name="<%= repo.name.toLowerCase() %>">
        <a class="repo-hit" href="<%= repoBase(repo) %>">
          <span class="repo-spine"></span>
          <span class="repo-body">
            <span class="repo-line">
              <span class="repo-name"><%= repo.name %></span>
              <% if (repo.private) { %><span class="tag tag-private" title="private">🔒</span><% } %>
              <% if (repo.archived) { %><span class="tag tag-archived">archived</span><% } %>
              <% if (repo.empty) { %>
                <span class="tag tag-empty">empty</span>
              <% } else { %>
                <span class="tag tag-branch"><%= repo.defaultBranch %></span>
              <% } %>
            </span>
            <% if (repo.description) { %>
              <span class="repo-desc"><%= repo.description %></span>
            <% } else { %>
              <span class="repo-desc muted">no description</span>
            <% } %>
          </span>
          <span class="repo-aside">
            <span class="repo-time"><%= repo.updatedAt.toLocaleDateString() %></span>
            <span class="repo-go">↵</span>
          </span>
        </a>
      </li>
    <% }); %>
  </ul>
<% } %>

<%- include("partials/footer") %>
