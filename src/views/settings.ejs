<%- include("partials/header", { title: "settings · " + repo.name, crumb: "~/repos/" + repo.slug + "/settings" }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">settings</span>
</section>

<%- include("partials/repobar") %>

<% if (error) { %>
  <div class="alert"><span class="alert-mark">✗</span> <%= error %></div>
<% } %>

<section class="card">
  <div class="card-head"><span class="card-title">visibility</span></div>
  <div class="settings-body">
    <p class="muted">
      This repository is currently
      <% if (repo.private) { %>
        <span class="tag tag-private">🔒 private</span> — visible only to the owner and collaborators.
      <% } else { %>
        <span class="tag tag-public"># public</span> — anyone who can reach this server can browse and clone it.
      <% } %>
    </p>
    <form method="post" action="<%= repoBase(repo) %>/settings/visibility" class="inline-form">
      <% if (repo.private) { %>
        <input type="hidden" name="visibility" value="public" />
        <button class="kbtn" type="submit">make public</button>
      <% } else { %>
        <input type="hidden" name="visibility" value="private" />
        <button class="kbtn" type="submit">make private</button>
      <% } %>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">collaborators</span></div>
  <div class="settings-body">
    <p class="muted">The owner <span class="ref-chip">@<%= repo.owner %></span> has full access.
      Collaborators can push and merge.</p>

    <ul class="collab-list">
      <% if (collaborators.length === 0) { %>
        <li class="muted">No collaborators yet.</li>
      <% } %>
      <% collaborators.forEach(function (c) { %>
        <li class="collab-row">
          <span class="collab-name"><span class="user-glyph">●</span> @<%= c %></span>
          <form method="post" action="<%= repoBase(repo) %>/settings/collaborators/remove" class="inline-form">
            <input type="hidden" name="username" value="<%= c %>" />
            <button class="kbtn" type="submit">remove</button>
          </form>
        </li>
      <% }); %>
    </ul>

    <form class="collab-add" method="post" action="<%= repoBase(repo) %>/settings/collaborators">
      <div class="field-mono">
        <span class="field-prefix">@</span>
        <input type="text" name="username" placeholder="username" autocomplete="off" autocapitalize="off" spellcheck="false" required />
      </div>
      <button class="kbtn primary" type="submit">add collaborator</button>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">labels</span></div>
  <div class="settings-body">
    <ul class="collab-list">
      <% if (labels.length === 0) { %><li class="muted">No labels.</li><% } %>
      <% labels.forEach(function (l) { %>
        <li class="collab-row">
          <span class="label-chip" style="color:<%= l.color %>;border-color:<%= l.color %>66;background:<%= l.color %>22"><%= l.name %></span>
          <form method="post" action="<%= repoBase(repo) %>/settings/labels/remove" class="inline-form">
            <input type="hidden" name="name" value="<%= l.name %>" />
            <button class="kbtn" type="submit">remove</button>
          </form>
        </li>
      <% }); %>
    </ul>

    <form class="collab-add label-add" method="post" action="<%= repoBase(repo) %>/settings/labels">
      <div class="field-mono">
        <input type="text" name="name" placeholder="label name" autocomplete="off" required />
      </div>
      <input type="color" name="color" value="#2f81f7" class="color-input" />
      <button class="kbtn primary" type="submit">add label</button>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">webhooks</span></div>
  <div class="settings-body">
    <p class="muted">
      POST a JSON payload to a URL after every push. Set a secret to receive an
      <code>X-Crux-Signature: sha256=…</code> HMAC over the body.
    </p>

    <ul class="collab-list">
      <% if (webhooks.length === 0) { %>
        <li class="muted">No webhooks yet.</li>
      <% } %>
      <% webhooks.forEach(function (h) { %>
        <li class="collab-row">
          <span class="collab-name">
            <span class="token-key">↗</span>
            <code class="webhook-url"><%= h.url %></code>
            <% if (h.secret) { %><span class="tag tag-branch">signed</span><% } %>
          </span>
          <form method="post" action="<%= repoBase(repo) %>/settings/webhooks/remove" class="inline-form">
            <input type="hidden" name="id" value="<%= h.id %>" />
            <button class="kbtn" type="submit">remove</button>
          </form>
        </li>
      <% }); %>
    </ul>

    <form class="form" method="post" action="<%= repoBase(repo) %>/settings/webhooks">
      <label class="field">
        <span class="field-label">payload URL</span>
        <div class="field-mono">
          <input type="url" name="url" placeholder="https://ci.example.com/hooks/crux" autocomplete="off" spellcheck="false" required />
        </div>
      </label>
      <label class="field">
        <span class="field-label">secret <span class="muted">(optional)</span></span>
        <div class="field-mono">
          <input type="text" name="secret" placeholder="for HMAC signing" autocomplete="off" spellcheck="false" />
        </div>
      </label>
      <div class="form-actions">
        <button class="kbtn primary" type="submit">add webhook</button>
      </div>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">repository</span></div>
  <div class="settings-body">
    <form class="collab-add" method="post" action="<%= repoBase(repo) %>/settings/rename">
      <div class="field-mono">
        <span class="field-prefix">crux/<%= repo.owner %>/</span>
        <input type="text" name="name" value="<%= repo.name %>" autocomplete="off" spellcheck="false" required />
      </div>
      <button class="kbtn" type="submit">rename</button>
    </form>

    <form class="collab-add" method="post" action="<%= repoBase(repo) %>/settings/transfer">
      <div class="field-mono">
        <span class="field-prefix">transfer to @</span>
        <input type="text" name="owner" placeholder="username" autocomplete="off" autocapitalize="off" spellcheck="false" required />
      </div>
      <button class="kbtn" type="submit">transfer</button>
    </form>

    <p class="muted">
      <% if (repo.archived) { %>
        This repository is <span class="tag tag-archived">archived</span> — read-only, pushes are refused.
      <% } else { %>
        Archiving makes the repository read-only (pushes refused). You can unarchive later.
      <% } %>
    </p>
    <form method="post" action="<%= repoBase(repo) %>/settings/archive" class="inline-form">
      <input type="hidden" name="archive" value="<%= repo.archived ? '0' : '1' %>" />
      <button class="kbtn" type="submit"><%= repo.archived ? 'unarchive' : 'archive' %></button>
    </form>
  </div>
</section>

<section class="card card-danger">
  <div class="card-head"><span class="card-title">delete repository</span></div>
  <div class="settings-body">
    <p class="muted">
      Permanently deletes <strong><%= repo.slug %></strong> and all its history,
      issues and pull requests. This cannot be undone.
    </p>
    <form class="collab-add" method="post" action="<%= repoBase(repo) %>/settings/delete"
          onsubmit="return confirm('Delete <%= repo.slug %>? This cannot be undone.')">
      <div class="field-mono">
        <input type="text" name="confirm" placeholder="type <%= repo.slug %> to confirm" autocomplete="off" spellcheck="false" required />
      </div>
      <button class="kbtn danger" type="submit">delete</button>
    </form>
  </div>
</section>

<%- include("partials/footer") %>
