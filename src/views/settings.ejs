<%- include("partials/header", { title: "settings · " + repo.name, crumb: "~/repos/" + repo.slug + "/settings" }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">settings</span>
</section>

<%- include("partials/repobar") %>

<% if (error) { %>
  <div class="alert"><span class="alert-mark">✗</span> <%= error %></div>
<% } %>

<section class="card">
  <div class="card-head"><span class="card-title">visibility</span></div>
  <div class="settings-body">
    <p class="muted">
      This repository is currently
      <% if (repo.private) { %>
        <span class="tag tag-private">🔒 private</span> — visible only to the owner and collaborators.
      <% } else { %>
        <span class="tag tag-public"># public</span> — anyone who can reach this server can browse and clone it.
      <% } %>
    </p>
    <form method="post" action="<%= repoBase(repo) %>/settings/visibility" class="inline-form">
      <% if (repo.private) { %>
        <input type="hidden" name="visibility" value="public" />
        <button class="kbtn" type="submit">make public</button>
      <% } else { %>
        <input type="hidden" name="visibility" value="private" />
        <button class="kbtn" type="submit">make private</button>
      <% } %>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">collaborators</span></div>
  <div class="settings-body">
    <p class="muted">The owner <span class="ref-chip">@<%= repo.owner %></span> has full access.
      Collaborators can push and merge.</p>

    <ul class="collab-list">
      <% if (collaborators.length === 0) { %>
        <li class="muted">No collaborators yet.</li>
      <% } %>
      <% collaborators.forEach(function (c) { %>
        <li class="collab-row">
          <span class="collab-name"><span class="user-glyph">●</span> @<%= c %></span>
          <form method="post" action="<%= repoBase(repo) %>/settings/collaborators/remove" class="inline-form">
            <input type="hidden" name="username" value="<%= c %>" />
            <button class="kbtn" type="submit">remove</button>
          </form>
        </li>
      <% }); %>
    </ul>

    <form class="collab-add" method="post" action="<%= repoBase(repo) %>/settings/collaborators">
      <div class="field-mono">
        <span class="field-prefix">@</span>
        <input type="text" name="username" placeholder="username" autocomplete="off" autocapitalize="off" spellcheck="false" required />
      </div>
      <button class="kbtn primary" type="submit">add collaborator</button>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">labels</span></div>
  <div class="settings-body">
    <ul class="collab-list">
      <% if (labels.length === 0) { %><li class="muted">No labels.</li><% } %>
      <% labels.forEach(function (l) { %>
        <li class="collab-row">
          <span class="label-chip" style="color:<%= l.color %>;border-color:<%= l.color %>66;background:<%= l.color %>22"><%= l.name %></span>
          <form method="post" action="<%= repoBase(repo) %>/settings/labels/remove" class="inline-form">
            <input type="hidden" name="name" value="<%= l.name %>" />
            <button class="kbtn" type="submit">remove</button>
          </form>
        </li>
      <% }); %>
    </ul>

    <form class="collab-add label-add" method="post" action="<%= repoBase(repo) %>/settings/labels">
      <div class="field-mono">
        <input type="text" name="name" placeholder="label name" autocomplete="off" required />
      </div>
      <input type="color" name="color" value="#2f81f7" class="color-input" />
      <button class="kbtn primary" type="submit">add label</button>
    </form>
  </div>
</section>

<%- include("partials/footer") %>
