<%- include("partials/header", { title: "create account", crumb: "~/register" }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">auth register</span>
</section>

<% if (error) { %>
  <div class="alert"><span class="alert-mark">✗</span> <%= error %></div>
<% } %>

<% if (mode === "bootstrap") { %>
  <div class="notice notice-accent">
    <span class="notice-mark">★</span>
    You're claiming a fresh instance — this first account becomes the <strong>admin</strong>.
  </div>
<% } %>

<% if (mode === "closed") { %>
  <div class="blank">
    <p>Registration is closed on this server.</p>
    <p class="muted">Ask an admin for an invite, or <a href="/login">sign in</a> if you already have an account.</p>
  </div>
<% } else { %>

<form class="form" method="post" action="/register">
  <input type="hidden" name="next" value="<%= next %>" />
  <% if (mode === "invite") { %>
    <label class="field">
      <span class="field-label">invite code</span>
      <div class="field-mono">
        <input type="text" name="invite" value="<%= values.invite %>" placeholder="paste your invite token" autocomplete="off" spellcheck="false" required />
      </div>
      <span class="field-hint">This server requires an invite to register.</span>
    </label>
  <% } %>
  <label class="field">
    <span class="field-label">username</span>
    <div class="field-mono">
      <span class="field-prefix">@</span>
      <input type="text" name="username" value="<%= values.username %>" autocomplete="username" autocapitalize="off" spellcheck="false" autofocus required />
    </div>
    <span class="field-hint">2–39 chars: letters, numbers, <code>.</code> <code>_</code> <code>-</code></span>
  </label>
  <label class="field">
    <span class="field-label">display name <span class="muted">(optional)</span></span>
    <div class="field-mono">
      <input type="text" name="displayName" value="<%= values.displayName %>" autocomplete="name" />
    </div>
  </label>
  <label class="field">
    <span class="field-label">password</span>
    <div class="field-mono">
      <input type="password" name="password" autocomplete="new-password" required />
    </div>
    <span class="field-hint">at least 8 characters.</span>
  </label>
  <div class="form-actions">
    <button class="kbtn primary" type="submit">create account</button>
    <a class="kbtn" href="/login">sign in instead</a>
  </div>
</form>
<% } %>

<%- include("partials/footer") %>
