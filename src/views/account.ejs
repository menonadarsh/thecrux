<%- include("partials/header", { title: "settings", crumb: "~/settings" }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">account settings</span>
</section>

<% if (error) { %>
  <div class="alert"><span class="alert-mark">✗</span> <%= error %></div>
<% } %>
<% if (notice) { %>
  <div class="notice notice-accent"><span class="notice-mark">✓</span> <%= notice %></div>
<% } %>

<section class="card">
  <div class="card-head"><span class="card-title">profile</span></div>
  <div class="settings-body">
    <form class="form" method="post" action="/settings/profile">
      <label class="field">
        <span class="field-label">username</span>
        <div class="field-mono">
          <span class="field-prefix">@</span>
          <input type="text" value="<%= currentUser.username %>" disabled />
        </div>
        <span class="field-hint">Usernames can't be changed.</span>
      </label>
      <label class="field">
        <span class="field-label">display name</span>
        <div class="field-mono">
          <input type="text" name="displayName" value="<%= currentUser.displayName %>" autocomplete="name" />
        </div>
      </label>
      <div class="form-actions">
        <button class="kbtn primary" type="submit">save profile</button>
      </div>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">password</span></div>
  <div class="settings-body">
    <form class="form" method="post" action="/settings/password">
      <label class="field">
        <span class="field-label">current password</span>
        <div class="field-mono">
          <input type="password" name="currentPassword" autocomplete="current-password" required />
        </div>
      </label>
      <label class="field">
        <span class="field-label">new password</span>
        <div class="field-mono">
          <input type="password" name="newPassword" autocomplete="new-password" required />
        </div>
        <span class="field-hint">at least 8 characters.</span>
      </label>
      <div class="form-actions">
        <button class="kbtn primary" type="submit">change password</button>
      </div>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">personal access tokens</span></div>
  <div class="settings-body">
    <p class="muted">
      Use a token in place of your password when cloning or pushing over HTTP —
      revocable, and per-device. Your password is never stored in git's config.
    </p>

    <% if (newToken) { %>
      <div class="notice notice-accent">
        <span class="notice-mark">★</span>
        <div>
          <strong>New token “<%= newToken.name %>”</strong> — copy it now, it won't be shown again.
        </div>
      </div>
      <div class="copy-row" data-copy="<%= newToken.secret %>">
        <code class="copy-text"><%= newToken.secret %></code>
        <button class="copy-btn" type="button" title="Copy">copy</button>
      </div>
      <p class="field-hint">
        Then: <code>git clone https://&lt;you&gt;:&lt;token&gt;@host/owner/repo.git</code> —
        or just paste the token when git prompts for a password.
      </p>
    <% } %>

    <ul class="collab-list">
      <% if (tokens.length === 0) { %>
        <li class="muted">No tokens yet.</li>
      <% } %>
      <% tokens.forEach(function (t) { %>
        <li class="collab-row">
          <span class="collab-name">
            <span class="token-key">🔑</span>
            <span class="token-name"><%= t.name %></span>
            <code class="token-tail">crux_pat_…<%= t.tail %></code>
            <span class="muted token-dates">
              created <%= new Date(t.createdAt).toLocaleDateString() %>
              · <%= t.lastUsedAt ? "last used " + new Date(t.lastUsedAt).toLocaleDateString() : "never used" %>
            </span>
          </span>
          <form method="post" action="/settings/tokens/revoke" class="inline-form">
            <input type="hidden" name="id" value="<%= t.id %>" />
            <button class="kbtn" type="submit">revoke</button>
          </form>
        </li>
      <% }); %>
    </ul>

    <form class="collab-add" method="post" action="/settings/tokens">
      <div class="field-mono">
        <input type="text" name="name" placeholder="token name — e.g. laptop, ci" autocomplete="off" required />
      </div>
      <button class="kbtn primary" type="submit">generate token</button>
    </form>
  </div>
</section>

<section class="card">
  <div class="card-head"><span class="card-title">SSH keys</span></div>
  <div class="settings-body">
    <p class="muted">
      Add a public key to clone and push over SSH. Paste the contents of your
      <code>.pub</code> file (e.g. <code>~/.ssh/id_ed25519.pub</code>).
    </p>

    <ul class="collab-list">
      <% if (sshKeys.length === 0) { %>
        <li class="muted">No SSH keys yet.</li>
      <% } %>
      <% sshKeys.forEach(function (k) { %>
        <li class="collab-row">
          <span class="collab-name">
            <span class="token-key">🔑</span>
            <span class="token-name"><%= k.name %></span>
            <code class="token-tail"><%= k.type %></code>
            <code class="ssh-fp"><%= k.fingerprint %></code>
            <span class="muted token-dates">
              added <%= new Date(k.createdAt).toLocaleDateString() %>
              · <%= k.lastUsedAt ? "last used " + new Date(k.lastUsedAt).toLocaleDateString() : "never used" %>
            </span>
          </span>
          <form method="post" action="/settings/ssh-keys/remove" class="inline-form">
            <input type="hidden" name="id" value="<%= k.id %>" />
            <button class="kbtn" type="submit">remove</button>
          </form>
        </li>
      <% }); %>
    </ul>

    <form class="form" method="post" action="/settings/ssh-keys">
      <label class="field">
        <span class="field-label">key name <span class="muted">(optional)</span></span>
        <div class="field-mono">
          <input type="text" name="name" placeholder="e.g. work laptop" autocomplete="off" />
        </div>
      </label>
      <label class="field">
        <span class="field-label">public key</span>
        <textarea class="ssh-key-input" name="publicKey" rows="3" placeholder="ssh-ed25519 AAAA… you@host" spellcheck="false" required></textarea>
      </label>
      <div class="form-actions">
        <button class="kbtn primary" type="submit">add SSH key</button>
      </div>
    </form>
  </div>
</section>

<section class="card card-danger">
  <div class="card-head"><span class="card-title">delete account</span></div>
  <div class="settings-body">
    <p class="muted">
      Permanently deletes your account<% if (repoCount > 0) { %> and its
      <strong><%= repoCount %> <%= repoCount === 1 ? "repository" : "repositories" %></strong><% } %>.
      This cannot be undone.
    </p>
    <form class="collab-add" method="post" action="/settings/delete"
          onsubmit="return confirm('Delete your account<%= repoCount > 0 ? " and " + repoCount + " repositories" : "" %>? This cannot be undone.')">
      <div class="field-mono">
        <span class="field-prefix">@</span>
        <input type="text" name="confirm" placeholder="type your username to confirm" autocomplete="off" autocapitalize="off" spellcheck="false" required />
      </div>
      <button class="kbtn danger" type="submit">delete account</button>
    </form>
  </div>
</section>

<%- include("partials/footer") %>
