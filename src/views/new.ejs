<%- include("partials/header", { title: "new repository", crumb: "~/repos/new" }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">init repository</span>
</section>

<% if (error) { %>
  <div class="alert"><span class="alert-mark">✗</span> <%= error %></div>
<% } %>

<form class="form" method="post" action="/new">
  <label class="field">
    <span class="field-label">name</span>
    <div class="field-mono">
      <% if (owners && owners.length > 1) { %>
        <select name="owner" class="owner-select">
          <% owners.forEach(function (o) { %>
            <option value="<%= o %>" <%= o === values.owner ? "selected" : "" %>><%= o %></option>
          <% }); %>
        </select>
        <span class="field-prefix">/</span>
      <% } else { %>
        <input type="hidden" name="owner" value="<%= values.owner %>" />
        <span class="field-prefix"><%= values.owner %>/</span>
      <% } %>
      <input
        type="text"
        name="name"
        value="<%= values.name %>"
        placeholder="my-project"
        autocomplete="off"
        spellcheck="false"
        autofocus
        required
      />
    </div>
    <span class="field-hint">letters, numbers, <code>.</code> <code>_</code> <code>-</code> — no spaces.</span>
  </label>

  <label class="field">
    <span class="field-label">description <span class="muted">(optional)</span></span>
    <div class="field-mono">
      <input
        type="text"
        name="description"
        value="<%= values.description %>"
        placeholder="what is this for?"
        autocomplete="off"
      />
    </div>
  </label>

  <fieldset class="field visibility-field">
    <span class="field-label">visibility</span>
    <% var vis = (locals.values && values.visibility) || "private"; %>
    <label class="vis-option">
      <input type="radio" name="visibility" value="private" <%= vis !== "public" ? "checked" : "" %> />
      <span class="vis-body">
        <span class="vis-title">🔒 private</span>
        <span class="vis-hint">Only you and collaborators can see and clone it.</span>
      </span>
    </label>
    <label class="vis-option">
      <input type="radio" name="visibility" value="public" <%= vis === "public" ? "checked" : "" %> />
      <span class="vis-body">
        <span class="vis-title"># public</span>
        <span class="vis-hint">Anyone who can reach this server can browse and clone it.</span>
      </span>
    </label>
  </fieldset>

  <div class="form-actions">
    <button class="kbtn primary" type="submit">create repository</button>
    <a class="kbtn" href="/">cancel</a>
  </div>
</form>

<%- include("partials/footer") %>
