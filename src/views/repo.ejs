<%- include("partials/header", { title: repo.name, crumb: "~/repos/" + repo.name }) %>

<section class="termline">
  <span class="termline-prompt">crux<span class="brand-caret">❯</span></span>
  <span class="termline-cmd">cd <%= repo.name %></span>
  <% if (repo.private) { %>
    <span class="tag tag-private">🔒 private</span>
  <% } else { %>
    <span class="tag tag-public"># public</span>
  <% } %>
  <% if (repo.empty) { %>
    <span class="tag tag-empty">empty</span>
  <% } else { %>
    <span class="tag tag-branch"><%= repo.defaultBranch %></span>
  <% } %>
</section>

<% if (repo.description) { %>
  <p class="repo-tagline"><%= repo.description %></p>
<% } %>

<section class="card">
  <div class="card-head"><span class="card-title">clone</span></div>
  <div class="copy-row" data-copy="<%= cloneUrl %>">
    <code class="copy-text">git clone <%= cloneUrl %></code>
    <button class="copy-btn" type="button" title="Copy">copy</button>
  </div>
</section>

<% if (repo.empty) { %>
  <section class="card">
    <div class="card-head"><span class="card-title">push an existing project</span></div>
<pre class="codeblock"><code>cd my-project
git init
git add .
git commit -m "Initial commit"
git branch -M main
git remote add origin <%= cloneUrl %>
git push -u origin main</code></pre>
  </section>
<% } else { %>
  <section class="card">
    <div class="card-head"><span class="card-title">default branch</span></div>
    <p><span class="tag tag-branch"><%= repo.defaultBranch %></span></p>
    <p class="muted">File browsing &amp; commit history land in the next increment.</p>
  </section>
<% } %>

<%- include("partials/footer") %>
