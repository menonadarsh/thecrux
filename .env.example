# thecrux configuration — copy to .env and adjust. All values are optional;
# the defaults shown are what the app uses when a variable is unset.

# --- Web server ---
PORT=3000
HOST=127.0.0.1                 # use 0.0.0.0 to listen on all interfaces

# --- Data ---
CRUX_DATA_DIR=./data           # repos, users, settings, secrets, SSH host key
# CRUX_REPOS_DIR=./data/repos  # override only if repos live elsewhere

# --- Secrets ---
# Session signing key. If unset, one is generated and persisted under the data
# dir. Pin it to keep sessions valid across rebuilds / multiple replicas.
# CRUX_SECRET=change-me-to-a-long-random-string

# --- Behind a reverse proxy / TLS ---
# Set when a proxy (Caddy/nginx/Traefik) terminates TLS, so req.protocol and the
# Secure cookie reflect X-Forwarded-Proto. "1" trusts the first proxy hop.
# CRUX_TRUST_PROXY=1
# Force Secure cookies even without HTTPS detection (rarely needed):
# CRUX_SECURE_COOKIES=1

# --- git over SSH ---
CRUX_SSH_ENABLED=true          # set 0/false to run HTTPS-only
CRUX_SSH_PORT=2222             # unprivileged; map host 22 -> 2222 at the proxy
# CRUX_SSH_HOST=0.0.0.0        # defaults to HOST
# Bring your own host key (PEM) so known_hosts stays stable across replicas:
# CRUX_SSH_HOST_KEY=/data/ssh_host_key
